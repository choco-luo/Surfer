{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "surfer",
  "version": "0.1.0",
  "identifier": "com.choco.surfer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "widget",
        "title": "surfer",
        "width": 300,
        "height": 72,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "resizable": false,
        "maximizable": false,
        "minimizable": false
      },
      {
        "label": "notebook",
        "title": "surfer — 筆記本",
        "width": 900,
        "height": 640,
        "visible": false,
        "center": true,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
